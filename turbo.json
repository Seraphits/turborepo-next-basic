{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "MONGO_URI"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
  "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "MONGO_URI"
      ]
    },
  "test": {
    "dependsOn": ["^build"],
     "env": [
        "MONGO_URI"
      ],
    "cache": false,
    "outputs": []
}
  }
}

